<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BikeMarket Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BikeMarket.styles.css" asp-append-version="true" />
</head>
<body class="admin-layout">
    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h4><i class="bi bi-bicycle"></i> BikeMarket</h4>
            <small class="text-muted">Admin Panel</small>
        </div>
        
        <ul class="sidebar-menu">
            <li class="menu-item">
                <a asp-controller="HomeAdmin" asp-action="Index" class="menu-link">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            
            <li class="menu-item">
                <a asp-controller="Moderation" asp-action="Index" class="menu-link">
                    <i class="bi bi-clipboard-check"></i>
                    <span>Post Moderation</span>
                    <span class="badge bg-warning text-dark ms-auto">New</span>
                </a>
            </li>
            
            <li class="menu-item">
                <a asp-controller="Vehicles" asp-action="Index" class="menu-link">
                    <i class="bi bi-bicycle"></i>
                    <span>Vehicles</span>
                </a>
            </li>
            
            <li class="menu-item">
                <a asp-controller="Users" asp-action="Index" class="menu-link">
                    <i class="bi bi-people"></i>
                    <span>Users</span>
                </a>
            </li>
            
            <li class="menu-item">
                <a asp-controller="Orders" asp-action="Index" class="menu-link">
                    <i class="bi bi-cart-check"></i>
                    <span>Orders</span>
                </a>
            </li>
            
            <li class="menu-item">
                <a asp-controller="Brands" asp-action="Index" class="menu-link">
                    <i class="bi bi-tags"></i>
                    <span>Brands</span>
                </a>
            </li>
            
            <li class="menu-item">
                <a asp-controller="Categories" asp-action="Index" class="menu-link">
                    <i class="bi bi-grid"></i>
                    <span>Categories</span>
                </a>
            </li>
            
            <li class="menu-divider"></li>
            
            <li class="menu-item">
                <a asp-controller="Home" asp-action="Index" class="menu-link">
                    <i class="bi bi-house"></i>
                    <span>Back to Site</span>
                </a>
            </li>
        </ul>
        
        <div class="sidebar-footer">
            <div class="user-info">
                <i class="bi bi-person-circle"></i>
                <div class="user-details">
                    <strong>@User.Identity?.Name</strong>
                    <small class="text-muted">Administrator</small>
                </div>
            </div>
            <form asp-controller="Users" asp-action="Logout" method="post" class="mt-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <!-- Top Navigation Bar -->
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
            <div class="container-fluid">
                <button class="btn btn-link sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list fs-4"></i>
                </button>
                
                <div class="ms-auto d-flex align-items-center">
                    <div class="dropdown">
                        <button class="btn btn-link text-dark dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-bell"></i>
                            <span class="badge bg-danger badge-sm">3</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">Notifications</h6></li>
                            <li><a class="dropdown-item" href="#">New post pending review</a></li>
                            <li><a class="dropdown-item" href="#">New user registered</a></li>
                            <li><a class="dropdown-item" href="#">New order received</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Page Content -->
        <div class="content-wrapper">
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="admin-footer">
            <div class="container-fluid">
                <span class="text-muted">&copy; 2026 BikeMarket Admin. All rights reserved.</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Sidebar Toggle
        document.getElementById('sidebarToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.getElementById('mainContent').classList.toggle('expanded');
        });

        // Active menu highlighting
        const currentPath = window.location.pathname;
        document.querySelectorAll('.sidebar-menu .menu-link').forEach(link => {
            if (link.getAttribute('href') === currentPath) {
                link.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
