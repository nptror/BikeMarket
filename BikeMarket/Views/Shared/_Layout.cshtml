<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="BikeMarket - Vietnam #1 Trusted Bicycle Marketplace" />
    <title>@ViewData["Title"] - BikeMarket</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BikeMarket.styles.css" asp-append-version="true" />
</head>
<body>
@using Microsoft.AspNetCore.Http

    <header>
        <nav class="navbar navbar-expand-sm navbar-market">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    🚲 BikeMarket
                </a>

                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto mb-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto mb-0 align-items-center gap-1">
                        @if (string.IsNullOrEmpty(Context.Session.GetString("UserId")))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Users" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-post-button" asp-controller="Users" asp-action="Register">Sign Up</a>
                            </li>
                        }
                        else
                        {
                            var userIdStr = Context.Session.GetString("UserId");
                            var userName = User.Identity?.Name;
                            var avatarInitial = !string.IsNullOrEmpty(userName) ? userName[0].ToString().ToUpperInvariant() : "U";

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Vehicles" asp-action="MyPost">My Listings</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-post-button" asp-controller="Vehicles" asp-action="Create">
                                    <i class="bi bi-plus-circle"></i> Post Ad
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-icon-link" asp-controller="Wishlists" asp-action="Index" aria-label="Wishlist" title="Wishlist">
                                    <i class="bi bi-heart"></i>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-icon-link" asp-controller="Chat" asp-action="Index" aria-label="Chat" title="Messages">
                                    <i class="bi bi-chat-dots"></i>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link p-0 d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="seller-avatar">@avatarInitial</div>
                                    <i class="bi bi-caret-down-fill dropdown-caret"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Users" asp-action="Profile" asp-route-id="@userIdStr">
                                            <i class="bi bi-person me-2"></i>Profile
                                        </a>
                                    </li>
                                    @if (User.IsInRole("admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item text-primary" asp-controller="HomeAdmin" asp-action="Index">
                                                <i class="bi bi-speedometer2 me-2"></i>Administration
                                            </a>
                                        </li>
                                    }
                                    <li>
                                        <a class="dropdown-item" asp-controller="Wishlists" asp-action="Index">
                                            <i class="bi bi-heart me-2"></i>Saved Ads
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Orders" asp-action="MyOrders">
                                            <i class="bi bi-bag-check me-2"></i>My Orders
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Vehicles" asp-action="MyPost">
                                            <i class="bi bi-card-list me-2"></i>My Listings
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Users" asp-action="Owner" asp-route-id="@userIdStr">
                                            <i class="bi bi-shop me-2"></i>My Store
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Home" asp-action="Privacy">
                                            <i class="bi bi-question-circle me-2"></i>Support
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Users" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-market">
        <div class="footer-grid">
            <div>
                <div class="footer-brand">🚲 BikeMarket</div>
                <p class="footer-desc">
                    Vietnam's leading online bicycle marketplace.
                    Connect buyers and sellers easily and quickly.
                </p>
            </div>
            <div>
                <div class="footer-title">Explore</div>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Policy</a></li>
                </ul>
            </div>
            <div>
                <div class="footer-title">Account</div>
                <ul class="footer-links">
                    <li><a asp-controller="Users" asp-action="Login">Login</a></li>
                    <li><a asp-controller="Users" asp-action="Register">Sign Up</a></li>
                </ul>
            </div>
            <div>
                <div class="footer-title">Contact</div>
                <ul class="footer-links">
                    <li><a href="#">support@bikemarket.vn</a></li>
                    <li><a href="#">Hotline: 1900-xxxx</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            &copy; 2026 BikeMarket. All rights reserved.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
