@model DataAccess.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-grid"></i> Category Details</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Categories</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-grid"></i> Category Information</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Category ID</dt>
                    <dd class="col-sm-8"><strong>#@Model.Id</strong></dd>

                    <dt class="col-sm-4">Category Name</dt>
                    <dd class="col-sm-8"><strong class="fs-5">@Model.Name</strong></dd>

                    <dt class="col-sm-4">Total Vehicles</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@Model.Vehicles.Count vehicle(s)</span>
                    </dd>
                </dl>
            </div>
        </div>

        @if (Model.Vehicles.Any())
        {
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-bicycle"></i> Vehicles in this Category</h5>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        @foreach (var vehicle in Model.Vehicles.Take(10))
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi bi-bicycle text-success"></i>
                                        <strong>@vehicle.Title</strong>
                                        <br>
                                        <small class="text-muted">Price: @vehicle.Price.ToString("N0") VND</small>
                                    </div>
                                    <span class="badge bg-@(vehicle.Status == "available" ? "success" : "secondary")">
                                        @vehicle.Status
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                    @if (Model.Vehicles.Count > 10)
                    {
                        <div class="text-center mt-3">
                            <small class="text-muted">And @(Model.Vehicles.Count - 10) more vehicles...</small>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="card shadow-sm mt-4">
                <div class="card-body text-center py-4">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">No vehicles in this category yet.</p>
                </div>
            </div>
        }

        <div class="mt-4">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>
