@model DataAccess.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<!-- Page Header -->
<div class="page-header">
    <h1><i class="bi bi-trash"></i> Delete Category</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Categories</a></li>
            <li class="breadcrumb-item active">Delete</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> <strong>Warning!</strong> Are you sure you want to delete this category?
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-grid"></i> Category Details</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">ID</dt>
                    <dd class="col-sm-9"><strong>#@Model.Id</strong></dd>

                    <dt class="col-sm-3">Category Name</dt>
                    <dd class="col-sm-9"><strong>@Model.Name</strong></dd>

                    <dt class="col-sm-3">Vehicles Count</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-secondary">@Model.Vehicles.Count vehicle(s)</span>
                    </dd>
                </dl>

                @if (Model.Vehicles.Count > 0)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-circle"></i> <strong>Important:</strong> This category is currently being used by <strong>@Model.Vehicles.Count</strong> vehicle(s). 
                        Deleting it may cause issues with those vehicles.
                    </div>
                }

                <hr>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Confirm Delete
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
