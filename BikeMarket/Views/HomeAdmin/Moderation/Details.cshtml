@model DTO.Vehicle.VehicleDetailDTO

@{
    ViewData["Title"] = "Review Post - Moderation";
}

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-clipboard-check"></i> Review Post</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Moderation</a></li>
                    <li class="breadcrumb-item active">Review</li>
                </ol>
            </nav>
        </div>
        <div>
            @if (Model.Status == "pending" || Model.Status == "Pending")
            {
                <button type="button" class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#approveModal">
                    <i class="bi bi-check-circle"></i> Approve Post
                </button>
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                    <i class="bi bi-x-circle"></i> Reject
                </button>
            }
            else
            {
                @if (Model.Status == "available")
                {
                    <span class="badge bg-success fs-6 px-3 py-2">
                        <i class="bi bi-check-circle"></i> Approved
                    </span>
                }
                else if (Model.Status == "rejected")
                {
                    <span class="badge bg-danger fs-6 px-3 py-2">
                        <i class="bi bi-x-circle"></i> Rejected
                    </span>
                }
            }
        </div>
    </div>
</div>

<div class="row">
    <!-- Images Section -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div id="carouselVehicleImages" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
                        {
                            @for (int i = 0; i < Model.ImageUrls.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@Model.ImageUrls[i]" class="d-block w-100" alt="Vehicle Image" style="max-height: 500px; object-fit: cover;">
                                </div>
                            }
                        }
                        else
                        {
                            <div class="carousel-item active">
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 500px;">
                                    <i class="bi bi-image text-muted" style="font-size: 5rem;"></i>
                                </div>
                            </div>
                        }
                    </div>
                    @if (Model.ImageUrls != null && Model.ImageUrls.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselVehicleImages" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselVehicleImages" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                        <div class="carousel-indicators">
                            @for (int i = 0; i < Model.ImageUrls.Count; i++)
                            {
                                <button type="button" data-bs-target="#carouselVehicleImages" data-bs-slide-to="@i" 
                                        class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Details Section -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-bicycle"></i> @Model.Title</h4>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <small class="text-muted d-block">Brand</small>
                        <strong>@Model.BrandName</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Category</small>
                        <strong>@Model.CategoryName</strong>
                    </div>
                    <div class="col-12">
                        <small class="text-muted d-block">Price</small>
                        <h3 class="text-success mb-0">@Model.Price.ToString("N0") VND</h3>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Condition</small>
                        <span class="badge bg-info">@Model.Condition</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Frame Size</small>
                        <strong>@Model.FrameSize</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Year</small>
                        <strong>@Model.YearManufactured</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Color</small>
                        <strong>@Model.Color</strong>
                    </div>
                    <div class="col-12">
                        <small class="text-muted d-block">Location</small>
                        <strong><i class="bi bi-geo-alt text-danger"></i> @Model.Location</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Status</small>
                        @if (Model.Status == "available")
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else if (Model.Status == "sold")
                        {
                            <span class="badge bg-secondary">Sold</span>
                        }
                        else if (Model.Status == "pending" || Model.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Pending Review</span>
                        }
                        else if (Model.Status == "rejected")
                        {
                            <span class="badge bg-danger">Rejected</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Model.Status</span>
                        }
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Posted Date</small>
                        <strong>@Model.CreatedAt?.ToString("MMM dd, yyyy")</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-person"></i> Seller Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6">
                        <small class="text-muted d-block">Seller Name</small>
                        <strong>@Model.SellerName</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Seller ID</small>
                        <strong>#@Model.SellerId</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Description Section -->
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-text-paragraph"></i> Description</h5>
            </div>
            <div class="card-body">
                <p class="mb-0">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-check-circle"></i> Confirm Approval</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to <strong>approve</strong> this post?</p>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> The post will be publicly visible to buyers after approval.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Approve" asp-route-id="@Model.VehicleId" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Confirm Approval
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Reject" asp-route-id="@Model.VehicleId" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-x-circle"></i> Reject Post</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to <strong>reject</strong> this post?</p>
                    <div class="mb-3">
                        <label for="reason" class="form-label">Reason for rejection (optional):</label>
                        <textarea class="form-control" id="reason" name="reason" rows="4" 
                                  placeholder="Enter the reason for rejecting this post..."></textarea>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> The reason will be sent to the seller.
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-circle"></i> Confirm Rejection
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
}
