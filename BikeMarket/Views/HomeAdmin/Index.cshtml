@model DTO.Dashboard.AdminDashboardDTO

@{
    ViewData["Title"] = "Admin Dashboard";
}

<!-- Page Header -->
<div class="page-header">
    <h1><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>
    </nav>
</div>

<!-- Welcome Alert -->
<div class="alert alert-info alert-dismissible fade show" role="alert">
    <i class="bi bi-info-circle me-2"></i>
    <strong>Welcome back!</strong> Here's what's happening with your BikeMarket today.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                <i class="bi bi-clipboard-check"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.PendingPostsCount</h3>
                <p class="mb-0">Pending Posts</p>
                <small class="text-muted">Awaiting review</small>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 mb-3">
        <div class="stat-card">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="bi bi-bicycle"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalVehiclesCount</h3>
                <p class="mb-0">Total Vehicles</p>
                <small class="text-success">+@Model.VehiclesThisWeek this week</small>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 mb-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalUsersCount</h3>
                <p class="mb-0">Total Users</p>
                <small class="text-primary">+@Model.UsersThisMonth this month</small>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 mb-3">
        <div class="stat-card">
            <div class="stat-icon bg-info bg-opacity-10 text-info">
                <i class="bi bi-cart-check"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.OrdersThisMonth</h3>
                <p class="mb-0">Orders</p>
                <small class="text-info">This month</small>
            </div>
        </div>
    </div>
</div>

<!-- Secondary Statistics -->
<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon bg-secondary bg-opacity-10 text-secondary">
                <i class="bi bi-tags"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalBrandsCount</h3>
                <p class="mb-0">Total Brands</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon bg-dark bg-opacity-10 text-dark">
                <i class="bi bi-grid"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalCategoriesCount</h3>
                <p class="mb-0">Total Categories</p>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row">
    <div class="col-12 mb-4">
        <h4 class="mb-3"><i class="bi bi-lightning-charge text-warning"></i> Quick Actions</h4>
    </div>
    
    <!-- Post Moderation -->
    <div class="col-md-4 mb-4">
        <div class="card dashboard-card border-start border-warning border-4">
            <div class="card-body text-center">
                <i class="bi bi-clipboard-check text-warning"></i>
                <h5 class="card-title mt-3">Post Moderation</h5>
                <p class="card-text text-muted">Review and approve new posts from sellers</p>
                @if (Model.PendingPostsCount > 0)
                {
                    <div class="alert alert-warning mb-3">
                        <strong>@Model.PendingPostsCount</strong> posts waiting for review
                    </div>
                }
                <a asp-controller="Moderation" asp-action="Index" class="btn btn-warning">
                    <i class="bi bi-arrow-right-circle"></i> View Pending Posts
                </a>
            </div>
        </div>
    </div>

    <!-- Manage Vehicles -->
    <div class="col-md-4 mb-4">
        <div class="card dashboard-card border-start border-success border-4">
            <div class="card-body text-center">
                <i class="bi bi-bicycle text-success"></i>
                <h5 class="card-title mt-3">Manage Vehicles</h5>
                <p class="card-text text-muted">View, edit and manage all vehicles for sale</p>
                <a asp-controller="Vehicles" asp-action="Index" class="btn btn-success">
                    <i class="bi bi-arrow-right-circle"></i> Manage Vehicles
                </a>
            </div>
        </div>
    </div>

    <!-- Manage Users -->
    <div class="col-md-4 mb-4">
        <div class="card dashboard-card border-start border-primary border-4">
            <div class="card-body text-center">
                <i class="bi bi-people text-primary"></i>
                <h5 class="card-title mt-3">Manage Users</h5>
                <p class="card-text text-muted">Manage user accounts and sellers</p>
                <a asp-controller="Users" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-arrow-right-circle"></i> Manage Users
                </a>
            </div>
        </div>
    </div>

    <!-- Manage Orders -->
    <div class="col-md-4 mb-4">
        <div class="card dashboard-card border-start border-info border-4">
            <div class="card-body text-center">
                <i class="bi bi-cart-check text-info"></i>
                <h5 class="card-title mt-3">Manage Orders</h5>
                <p class="card-text text-muted">View and manage all orders</p>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-info text-white">
                    <i class="bi bi-arrow-right-circle"></i> View Orders
                </a>
            </div>
        </div>
    </div>

    <!-- Manage Brands -->
    <div class="col-md-4 mb-4">
        <div class="card dashboard-card border-start border-secondary border-4">
            <div class="card-body text-center">
                <i class="bi bi-tags text-secondary"></i>
                <h5 class="card-title mt-3">Manage Brands</h5>
                <p class="card-text text-muted">Manage bike brands and categories</p>
                <a asp-controller="Brands" asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-right-circle"></i> Manage Brands
                </a>
            </div>
        </div>
    </div>

    <!-- Manage Categories -->
    <div class="col-md-4 mb-4">
        <div class="card dashboard-card border-start border-dark border-4">
            <div class="card-body text-center">
                <i class="bi bi-grid text-dark"></i>
                <h5 class="card-title mt-3">Manage Categories</h5>
                <p class="card-text text-muted">Manage vehicle categories and types</p>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-dark">
                    <i class="bi bi-arrow-right-circle"></i> Manage Categories
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> System Overview</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-muted">Content Management</h6>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Total Vehicles
                                <span class="badge bg-success rounded-pill">@Model.TotalVehiclesCount</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Pending Review
                                <span class="badge bg-warning text-dark rounded-pill">@Model.PendingPostsCount</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                New This Week
                                <span class="badge bg-info rounded-pill">@Model.VehiclesThisWeek</span>
                            </li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">User & Commerce</h6>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Total Users
                                <span class="badge bg-primary rounded-pill">@Model.TotalUsersCount</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                New Users This Month
                                <span class="badge bg-info rounded-pill">@Model.UsersThisMonth</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Orders This Month
                                <span class="badge bg-success rounded-pill">@Model.OrdersThisMonth</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>