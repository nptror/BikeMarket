@model IEnumerable<DTO.User.UserProfileDTO>

@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-people"></i> Manage Users</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Users</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-person-plus"></i> Add New User
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search and Filter Form -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">
                    <i class="bi bi-search"></i> Search by Name or Email
                </label>
                <input type="text" name="search" class="form-control" placeholder="Search..." value="@ViewBag.Search" />
            </div>
            
            <div class="col-md-2">
                <label class="form-label">
                    <i class="bi bi-star"></i> Min Rating
                </label>
                <input type="number" name="ratingAvg" class="form-control" min="0" max="5" step="0.1" value="@ViewBag.RatingAvg" />
            </div>
            
            <div class="col-md-2">
                <label class="form-label">
                    <i class="bi bi-shield"></i> Role
                </label>
                <select name="role" class="form-select">
                    <option value="">All Roles</option>
                    <option value="buyer" selected="@(ViewBag.Role == "buyer")">Buyer</option>
                    <option value="seller" selected="@(ViewBag.Role == "seller")">Seller</option>
                    <option value="admin" selected="@(ViewBag.Role == "admin")">Admin</option>
                </select>
            </div>
            
            <div class="col-md-2">
                <label class="form-label">
                    <i class="bi bi-sort-down"></i> Sort By
                </label>
                <select name="sortBy" class="form-select">
                    <option value="email" selected="@(ViewBag.SortBy == "email")">Email</option>
                    <option value="name" selected="@(ViewBag.SortBy == "name")">Name</option>
                    <option value="ratingavg" selected="@(ViewBag.SortBy == "ratingavg")">Rating</option>
                </select>
            </div>
            
            <div class="col-md-2">
                <label class="form-label">
                    <i class="bi bi-arrow-down-up"></i> Order
                </label>
                <select name="sortOrder" class="form-select">
                    <option value="asc" selected="@(ViewBag.SortOrder == "asc")">Ascending</option>
                    <option value="desc" selected="@(ViewBag.SortOrder == "desc")">Descending</option>
                </select>
            </div>
            
            <div class="col-12">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel"></i> Apply Filters
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-circle"></i> Clear
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count()</h3>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-info bg-opacity-10 text-info">
                <i class="bi bi-person-check"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "buyer")</h3>
                <p class="mb-0">Buyers</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="bi bi-shop"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "seller")</h3>
                <p class="mb-0">Sellers</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "admin")</h3>
                <p class="mb-0">Admins</p>
            </div>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="card shadow-sm admin-table">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 5rem;"></i>
                <h4 class="mt-3">No Users Found</h4>
                <p class="text-muted">Try adjusting your filters or search terms.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Rating</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-2">
                                            @item.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <strong>@item.Name</strong>
                                    </div>
                                </td>
                                <td>@item.Email</td>
                                <td>@(item.Phone ?? "N/A")</td>
                                <td>
                                    @if (item.Role == "admin")
                                    {
                                        <span class="badge bg-warning text-dark">Admin</span>
                                    }
                                    else if (item.Role == "seller")
                                    {
                                        <span class="badge bg-success">Seller</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">Buyer</span>
                                    }
                                </td>
                                <td>
                                    @if (item.RatingAvg > 0)
                                    {
                                        <span class="text-warning">
                                            <i class="bi bi-star-fill"></i> @item.RatingAvg.ToString("F1")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No rating</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
.avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.1rem;
}
</style>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
