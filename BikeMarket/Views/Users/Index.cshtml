@model IEnumerable<DataAccess.Models.User>

@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-people"></i> Manage Users</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Users</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-person-plus"></i> Add New User
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count()</h3>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-info bg-opacity-10 text-info">
                <i class="bi bi-person-check"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "buyer")</h3>
                <p class="mb-0">Buyers</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="bi bi-shop"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "seller")</h3>
                <p class="mb-0">Sellers</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "admin")</h3>
                <p class="mb-0">Admins</p>
            </div>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="card shadow-sm admin-table">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 5rem;"></i>
                <h4 class="mt-3">No Users Found</h4>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Rating</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-2">
                                            @item.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <strong>@item.Name</strong>
                                            @if (item.EmailVerified == true)
                                            {
                                                <i class="bi bi-patch-check-fill text-primary" title="Verified"></i>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>@item.Email</td>
                                <td>@(item.Phone ?? "N/A")</td>
                                <td>
                                    @if (item.Role == "admin")
                                    {
                                        <span class="badge bg-warning text-dark">Admin</span>
                                    }
                                    else if (item.Role == "seller")
                                    {
                                        <span class="badge bg-success">Seller</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">Buyer</span>
                                    }
                                </td>
                                <td>
                                    @if (item.RatingAvg.HasValue && item.RatingAvg.Value > 0)
                                    {
                                        <span class="text-warning">
                                            <i class="bi bi-star-fill"></i> @item.RatingAvg.Value.ToString("F1")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No rating</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else if (item.Status == "inactive")
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                    else if (item.Status == "suspended")
                                    {
                                        <span class="badge bg-danger">Suspended</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td>
                                    <small>@item.CreatedAt?.ToString("MM/dd/yyyy")</small>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
.avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.1rem;
}
</style>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
