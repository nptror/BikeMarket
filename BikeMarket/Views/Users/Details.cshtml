@model DataAccess.Models.User

@{
    ViewData["Title"] = "User Details";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-person"></i> User Details</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Users</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-people"></i> User Information</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="avatar-circle-large mx-auto">
                        @Model.Name.Substring(0, 1).ToUpper()
                    </div>
                    <h3 class="mt-3">@Model.Name</h3>
                    @if (Model.EmailVerified == true)
                    {
                        <span class="badge bg-primary">
                            <i class="bi bi-patch-check-fill"></i> Verified Account
                        </span>
                    }
                </div>

                <dl class="row">
                    <dt class="col-sm-4">User ID</dt>
                    <dd class="col-sm-8"><strong>#@Model.Id</strong></dd>

                    <dt class="col-sm-4">Email Address</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Phone Number</dt>
                    <dd class="col-sm-8">@(Model.Phone ?? "Not provided")</dd>

                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8">
                        @if (Model.Role == "admin")
                        {
                            <span class="badge bg-warning text-dark fs-6">
                                <i class="bi bi-shield-check"></i> Admin
                            </span>
                        }
                        else if (Model.Role == "seller")
                        {
                            <span class="badge bg-success fs-6">
                                <i class="bi bi-shop"></i> Seller
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-info fs-6">
                                <i class="bi bi-person-check"></i> Buyer
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-4">Account Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.Status == "active")
                        {
                            <span class="badge bg-success fs-6">Active</span>
                        }
                        else if (Model.Status == "inactive")
                        {
                            <span class="badge bg-secondary fs-6">Inactive</span>
                        }
                        else if (Model.Status == "suspended")
                        {
                            <span class="badge bg-danger fs-6">Suspended</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">@Model.Status</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Rating</dt>
                    <dd class="col-sm-8">
                        @if (Model.RatingAvg.HasValue && Model.RatingAvg.Value > 0)
                        {
                            <span class="text-warning fs-5">
                                <i class="bi bi-star-fill"></i> @Model.RatingAvg.Value.ToString("F1")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">No rating yet</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Member Since</dt>
                    <dd class="col-sm-8">@Model.CreatedAt?.ToString("MMMM dd, yyyy")</dd>
                </dl>
            </div>
        </div>

        <!-- User Activity -->
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-activity"></i> User Activity</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-4">
                        <div class="p-3">
                            <i class="bi bi-bicycle text-success" style="font-size: 2rem;"></i>
                            <h4 class="mt-2">@Model.Vehicles.Count</h4>
                            <p class="text-muted mb-0">Vehicles Posted</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3">
                            <i class="bi bi-cart-check text-primary" style="font-size: 2rem;"></i>
                            <h4 class="mt-2">@Model.OrderBuyers.Count</h4>
                            <p class="text-muted mb-0">Orders as Buyer</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3">
                            <i class="bi bi-shop text-info" style="font-size: 2rem;"></i>
                            <h4 class="mt-2">@Model.OrderSellers.Count</h4>
                            <p class="text-muted mb-0">Orders as Seller</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Vehicles.Any())
        {
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-bicycle"></i> Recent Vehicles</h5>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        @foreach (var vehicle in Model.Vehicles.OrderByDescending(v => v.CreatedAt).Take(5))
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi bi-bicycle text-success"></i>
                                        <strong>@vehicle.Title</strong>
                                        <br>
                                        <small class="text-muted">Price: @vehicle.Price.ToString("N0") VND</small>
                                    </div>
                                    <span class="badge bg-@(vehicle.Status == "available" ? "success" : "secondary")">
                                        @vehicle.Status
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                    @if (Model.Vehicles.Count > 5)
                    {
                        <div class="text-center mt-3">
                            <small class="text-muted">And @(Model.Vehicles.Count - 5) more vehicles...</small>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="mt-4">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>

<style>
.avatar-circle-large {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 2.5rem;
}
</style>
