@using DTO.User
@model UserLoginDTO

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <a href="/" class="auth-logo">🚲 BikeMarket</a>
            <h1 class="auth-title">Welcome Back!</h1>
            <p class="auth-subtitle">Login to manage your listings and shop</p>
        </div>

        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label asp-for="Email" class="auth-label">Your Email</label>
                <div class="auth-input-group">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" class="auth-input" placeholder="YourName@example.com" autofocus />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <label asp-for="Password" class="auth-label">Password</label>
                    <a href="#" class="auth-link" style="font-size: 13px;">Forgot password?</a>
                </div>
                <div class="auth-input-group">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" type="password" class="auth-input" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="auth-btn">Login</button>
        </form>

        <div class="auth-footer">
            <span>Don't have an account?</span>
            <a asp-controller="Users" asp-action="Register" class="auth-link">Sign Up Now</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
