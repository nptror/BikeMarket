@model DataAccess.Models.User

@{
    ViewData["Title"] = "Edit User";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="page-header">
    <h1><i class="bi bi-pencil"></i> Edit User</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Users</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-people"></i> Edit User #@Model.Id</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="RatingAvg" />
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">
                                <i class="bi bi-person"></i> Full Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label">
                                <i class="bi bi-envelope"></i> Email Address <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label">
                                <i class="bi bi-telephone"></i> Phone Number
                            </label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Role" class="form-label">
                                <i class="bi bi-shield"></i> Role <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Role" class="form-select">
                                <option value="buyer">Buyer</option>
                                <option value="seller">Seller</option>
                                <option value="admin">Admin</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label">
                                <i class="bi bi-activity"></i> Status <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Status" class="form-select">
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                                <option value="suspended">Suspended</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="bi bi-patch-check"></i> Email Verified
                            </label>
                            <div class="form-check form-switch">
                                <input type="hidden" name="EmailVerified" value="false" />
                                <input name="EmailVerified" class="form-check-input" type="checkbox" role="switch" value="true" @(Model.EmailVerified == true ? "checked" : "") />
                                <label class="form-check-label">Verified</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PasswordHash" class="form-label">
                            <i class="bi bi-lock"></i> Password Hash
                        </label>
                        <input asp-for="PasswordHash" class="form-control" readonly />
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Password cannot be changed here. User must reset password themselves.
                        </small>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> <strong>Account Info:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Created: <strong>@Model.CreatedAt?.ToString("MMMM dd, yyyy HH:mm")</strong></li>
                            <li>Rating: <strong>@(Model.RatingAvg?.ToString("F1") ?? "No rating")</strong> ⭐</li>
                        </ul>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
