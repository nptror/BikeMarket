@using DTO.User
@model UserRegisterDTO

<!-- Page Header -->


<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-people"></i> Đăng ký tài khoản</h5>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-person"></i> Họ và tên <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">
                            <i class="bi bi-envelope"></i> Email <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Email" class="form-control form-control-lg" type="email" placeholder="user@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Email phải là duy nhất
                        </small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">
                            <i class="bi bi-lock"></i> Mật khẩu <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Password" class="form-control form-control-lg" type="password" placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Tối thiểu 6 ký tự
                        </small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">
                            <i class="bi bi-telephone"></i> Số điện thoại
                        </label>
                        <input asp-for="Phone" class="form-control form-control-lg" placeholder="(Không bắt buộc)" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Đăng ký
                        </button>
                        <a asp-action="Login" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
