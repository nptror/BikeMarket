@using DTO.User
@model UserRegisterDTO

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card" style="max-width: 500px;">
        <div class="auth-header">
            <a href="/" class="auth-logo">🚲 BikeMarket</a>
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle">Join the largest bicycle trading community</p>
        </div>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label asp-for="Name" class="auth-label">Full Name <span class="text-danger">*</span></label>
                <div class="auth-input-group">
                    <i class="bi bi-person"></i>
                    <input asp-for="Name" class="auth-input" placeholder="Enter your full name" autofocus />
                </div>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="auth-label">Email Address <span class="text-danger">*</span></label>
                <div class="auth-input-group">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" type="email" class="auth-input" placeholder="YourName@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 form-group">
                    <label asp-for="Password" class="auth-label">Password <span class="text-danger">*</span></label>
                    <div class="auth-input-group">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" type="password" class="auth-input" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group">
                    <label asp-for="Phone" class="auth-label">Phone Number</label>
                    <div class="auth-input-group">
                        <i class="bi bi-telephone"></i>
                        <input asp-for="Phone" class="auth-input" placeholder="09xx xxx xxx" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mt-2">
                <p style="font-size: 13px; color: #888;">
                    By registering, you agree to our <a href="#" class="auth-link">Terms of Use</a>.
                </p>
            </div>

            <button type="submit" class="auth-btn">Register Account</button>
        </form>

        <div class="auth-footer">
            <span>Already have an account?</span>
            <a asp-controller="Users" asp-action="Login" class="auth-link">Login Now</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
