@model BikeMarket.Models.OrderPaymentSuccessViewModel

@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h3 class="text-success mb-3">
                <i class="bi bi-check-circle-fill"></i> Thanh toán thành công
            </h3>
            <p class="text-muted">Cảm ơn bạn đã mua hàng.</p>

            <div class="row g-3 mt-3">
                <div class="col-md-6">
                    <div class="fw-semibold">Đơn hàng</div>
                    <div>#@Model.Order.Id</div>
                </div>
                <div class="col-md-6">
                    <div class="fw-semibold">Sản phẩm</div>
                    <div>@Model.Order.Vehicle?.Title</div>
                </div>
                <div class="col-md-6">
                    <div class="fw-semibold">Người bán</div>
                    <div>@Model.Order.Seller?.Name</div>
                </div>
                <div class="col-md-6">
                    <div class="fw-semibold">Tổng tiền</div>
                    <div class="text-danger fw-semibold">@Model.Order.TotalAmount.ToString("N0") ₫</div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                @if (Model.CanRateSeller)
                {
                    <a asp-controller="UserRatings" asp-action="Create" asp-route-orderId="@Model.Order.Id" class="btn btn-warning">
                        <i class="bi bi-star-fill"></i> Đánh giá người bán
                    </a>
                }
                <a asp-controller="Vehicles" asp-action="DetailsBuyer" asp-route-id="@Model.Order.VehicleId" class="btn btn-outline-secondary">
                    Quay lại sản phẩm
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
