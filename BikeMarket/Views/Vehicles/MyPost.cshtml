@model BikeMarket.Models.VehicleMyPostViewModel

@{
    ViewData["Title"] = "MyPost";
}

<div class="content-nav">
    <a class="content-nav-link @(Model.ActiveTab == "display" ? "active" : "")" asp-action="MyPost" asp-route-tab="display">
         ĐANG HIỂN THỊ (@Model.DisplayCount)
    </a>
    <a class="content-nav-link @(Model.ActiveTab == "draft" ? "active" : "")" asp-action="MyPost" asp-route-tab="draft">
        TIN NHÁP (@Model.DraftCount)
    </a>
    <a class="content-nav-link @(Model.ActiveTab == "pending" ? "active" : "")" asp-action="MyPost" asp-route-tab="pending">
         CHỜ DUYỆT (@Model.PendingCount)
    </a>
    <a class="content-nav-link @(Model.ActiveTab == "denied" ? "active" : "")" asp-action="MyPost" asp-route-tab="denied">
         BỊ TỪ CHỐI (@Model.DeniedCount)
    </a>
</div>

<div class="mt-3">
    <h1>MyPost</h1>

    @if (Model.Vehicles.Count == 0)
    {
        <div class="text-muted">Chưa có tin đăng.</div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Giá</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Vehicles)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Price.ToString("C0")</td>
                    <td>@(string.IsNullOrEmpty(item.Status) ? "available" : item.Status)</td>
                    <td>@item.CreatedAt?.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-action="DetailsAdmin" asp-route-id="@item.VehicleId">Details</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
