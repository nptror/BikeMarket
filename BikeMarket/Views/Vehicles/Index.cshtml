@model IEnumerable<DataAccess.Models.Vehicle>

@{
    ViewData["Title"] = "Manage Vehicles";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-bicycle"></i> Manage Vehicles</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Vehicles</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add New Vehicle
            </a>
        </div>
    </div>
</div>

<!-- Statistics -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="bi bi-bicycle"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count()</h3>
                <p class="mb-0">Total Vehicles</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(v => v.Status == "available")</h3>
                <p class="mb-0">Available</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                <i class="bi bi-clock"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(v => v.Status == "pending")</h3>
                <p class="mb-0">Pending</p>
            </div>
        </div>
    </div>
</div>

<!-- Vehicles Table -->
<div class="card shadow-sm admin-table">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 5rem;"></i>
                <h4 class="mt-3">No Vehicles Found</h4>
                <p class="text-muted">Start by adding your first vehicle.</p>
                <a asp-action="Create" class="btn btn-success mt-3">
                    <i class="bi bi-plus-circle"></i> Add First Vehicle
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Brand</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Condition</th>
                            <th>Status</th>
                            <th>Seller</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Title</strong>
                                    @if (!string.IsNullOrEmpty(item.FrameSize))
                                    {
                                        <br><small class="text-muted">Size: @item.FrameSize</small>
                                    }
                                </td>
                                <td>@item.Brand?.Name</td>
                                <td>@item.Category?.Name</td>
                                <td><strong class="text-success">@item.Price.ToString("N0") VND</strong></td>
                                <td><span class="badge bg-info">@item.Condition</span></td>
                                <td>
                                    @if (item.Status == "available")
                                    {
                                        <span class="badge bg-success">Available</span>
                                    }
                                    else if (item.Status == "pending")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (item.Status == "sold")
                                    {
                                        <span class="badge bg-secondary">Sold</span>
                                    }
                                    else if (item.Status == "rejected")
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td>@item.Seller?.Name</td>
                                <td>
                                    <small>@item.CreatedAt?.ToString("MM/dd/yyyy")</small>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="DetailsAdmin" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
