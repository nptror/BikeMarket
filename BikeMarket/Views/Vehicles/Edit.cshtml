@model DataAccess.Models.Vehicle

@{
    ViewData["Title"] = "Edit";
}

<div class="container-lg py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0">Chỉnh sửa tin</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="SellerId" />

                <div class="row g-3">
                    <div class="col-lg-8">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Tiêu đề</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="BrandId" class="form-label">Hãng</label>
                                <select asp-for="BrandId" class="form-select" asp-items="ViewBag.BrandId"></select>
                                <span asp-validation-for="BrandId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label">Danh mục</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label">Giá</label>
                                <input asp-for="Price" class="form-control" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FrameSize" class="form-label">Kích thước khung</label>
                                <input asp-for="FrameSize" class="form-control" />
                                <span asp-validation-for="FrameSize" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Condition" class="form-label">Tình trạng</label>
                                <input asp-for="Condition" class="form-control" />
                                <span asp-validation-for="Condition" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="YearManufactured" class="form-label">Năm sản xuất</label>
                                <input asp-for="YearManufactured" class="form-control" />
                                <span asp-validation-for="YearManufactured" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Location" class="form-label">Địa điểm</label>
                                <input asp-for="Location" class="form-control" />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Color" class="form-label">Màu sắc</label>
                                <input asp-for="Color" class="form-control" />
                                <span asp-validation-for="Color" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label">Trạng thái</label>
                                <input asp-for="Status" class="form-control" />
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CreatedAt" class="form-label">Ngày tạo</label>
                                <input asp-for="CreatedAt" class="form-control" />
                                <span asp-validation-for="CreatedAt" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="create-section">
                            <div class="mb-2 fw-semibold">Hình ảnh</div>
                            <input type="file" id="newImages" name="newImages" class="image-input-hidden" accept="image/*" multiple />
                            <div class="image-preview-grid mt-3" id="editImagePreview">
                                @if (Model.VehicleImages != null)
                                {
                                    foreach (var image in Model.VehicleImages)
                                    {
                                        <div class="image-preview-wrapper">
                                            <img src="@image.ImageUrl" class="image-preview-item" alt="Vehicle image" />
                                            <form asp-action="DeleteImage" method="post" class="image-delete-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imageId" value="@image.Id" />
                                                <input type="hidden" name="vehicleId" value="@Model.Id" />
                                                <button type="submit" class="image-delete-button" title="Xóa ảnh">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                }
                                <label for="newImages" class="image-upload-tile">+</label>
                            </div>
                            <small class="form-text text-muted">Bạn có thể thêm nhiều ảnh mới</small>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Lưu thay đổi</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('newImages').addEventListener('change', function () {
            const preview = document.getElementById('editImagePreview');
            const uploadTile = preview.querySelector('.image-upload-tile');
            preview.querySelectorAll('.image-preview-wrapper.new-image').forEach(item => item.remove());

            Array.from(this.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = function (event) {
                    const wrapper = document.createElement('div');
                    wrapper.classList.add('image-preview-wrapper', 'new-image');

                    const img = document.createElement('img');
                    img.src = event.target.result;
                    img.classList.add('image-preview-item');

                    wrapper.appendChild(img);
                    preview.insertBefore(wrapper, uploadTile);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}
