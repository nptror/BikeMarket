@model DataAccess.Models.Vehicle

@{
    ViewData["Title"] = "Edit";
}

<!-- Delete image form placed OUTSIDE the main edit form -->
<form id="deleteImageForm" method="post" asp-action="DeleteImage" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="imageId" id="deleteImageId" />
    <input type="hidden" name="vehicleId" id="deleteVehicleId" value="@Model.Id" />
</form>

<div class="container-lg py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0">Chỉnh sửa tin</h1>
        <a asp-action="MyPost" class="btn btn-outline-secondary">Quay lại</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="SellerId" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="row g-3">
                    <div class="col-lg-8">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Tiêu đề</label>
                            <input asp-for="Title" class="form-control" id="titleInput" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4" id="descriptionInput"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="BrandId" class="form-label">Hãng</label>
                                <select asp-for="BrandId" class="form-select" asp-items="ViewBag.BrandId" id="brandInput"></select>
                                <span asp-validation-for="BrandId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label">Danh mục</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" id="categoryInput"></select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label">Giá</label>
                                <input asp-for="Price" class="form-control" id="priceInput" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FrameSize" class="form-label">Kích thước khung</label>
                                <input asp-for="FrameSize" class="form-control" id="frameSizeInput" />
                                <span asp-validation-for="FrameSize" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Condition" class="form-label">Tình trạng</label>
                                <select asp-for="Condition" class="form-select" id="conditionInput">
                                    <option value="">-- Select Condition --</option>
                                    <option value="excellent">Excellent</option>
                                    <option value="good">Good</option>
                                    <option value="fair">Fair</option>
                                    <option value="poor">Poor</option>
                                </select>
                                <span asp-validation-for="Condition" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="YearManufactured" class="form-label">Năm sản xuất</label>
                                <input asp-for="YearManufactured" class="form-control" type="number" id="yearInput" />
                                <span asp-validation-for="YearManufactured" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Location" class="form-label">Địa điểm</label>
                                <input asp-for="Location" class="form-control" id="locationInput" />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Color" class="form-label">Màu sắc</label>
                                <input asp-for="Color" class="form-control" id="colorInput" />
                                <span asp-validation-for="Color" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label">Trạng thái</label>
                                <select asp-for="Status" class="form-select" id="statusInput">
                                    <option value="">-- Select Status --</option>
                                    <option value="available">Available</option>
                                    <option value="pending">Pending</option>
                                    <option value="draft">Draft</option>
                                    <option value="denied">Denied</option>
                                    <option value="sold">Sold</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="create-section">
                            <div class="mb-2 fw-semibold">Hình ảnh</div>
                            <input type="file" id="newImages" name="newImages" class="image-input-hidden" accept="image/*" multiple />
                            <div class="image-preview-grid mt-3" id="editImagePreview">
                                @if (Model.VehicleImages != null)
                                {
                                    foreach (var image in Model.VehicleImages)
                                    {
                                        <div class="image-preview-wrapper existing-image" data-url="@image.ImageUrl">
                                            <img src="@image.ImageUrl" class="image-preview-item" alt="Vehicle image" />
                                            <button type="button" class="image-delete-button" title="Xóa ảnh"
                                                    onclick="deleteImage(@image.Id)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                }
                                <label for="newImages" class="image-upload-tile">+</label>
                            </div>
                            <small class="form-text text-muted">Bạn có thể thêm nhiều ảnh mới</small>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="button" class="btn btn-outline-primary btn-lg" onclick="showPreview()">
                                <i class="bi bi-eye"></i> Xem trước
                            </button>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-save"></i> Lưu thay đổi
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Preview Modal -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="previewModalLabel">
                    <i class="bi bi-eye"></i> Xem trước bài đăng
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                <div class="row">
                    <!-- Left: Images -->
                    <div class="col-lg-6 mb-4">
                        <div class="preview-gallery">
                            <div id="previewCarousel" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner" id="previewCarouselInner" style="border-radius: 12px; overflow: hidden;">
                                    <div class="carousel-item active">
                                        <div style="background: #f5f5f5; height: 400px; display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                                        </div>
                                    </div>
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#previewCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#previewCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                                <div class="carousel-indicators" id="previewCarouselIndicators"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Details -->
                    <div class="col-lg-6">
                        <div class="preview-details">
                            <h2 id="previewTitle" class="mb-3" style="font-size: 24px; font-weight: 600;">Tiêu đề bài đăng</h2>
                            
                            <div class="preview-price mb-4">
                                <div style="font-size: 32px; font-weight: 700; color: #198754;" id="previewPrice">0 ₫</div>
                                <div class="mt-2">
                                    <span class="badge bg-success" id="previewStatusBadge">Available</span>
                                    <span class="badge bg-info">Giá tốt</span>
                                </div>
                            </div>

                            <div class="preview-specs mb-4">
                                <h5 class="mb-3" style="font-size: 18px; font-weight: 600;">Thông tin chi tiết</h5>
                                <div class="row g-3">
                                    <div class="col-6">
                                        <div class="spec-item">
                                            <small class="text-muted d-block">Hãng</small>
                                            <strong id="previewBrand">-</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="spec-item">
                                            <small class="text-muted d-block">Danh mục</small>
                                            <strong id="previewCategory">-</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="spec-item">
                                            <small class="text-muted d-block">Tình trạng</small>
                                            <span class="badge bg-info" id="previewCondition">-</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="spec-item">
                                            <small class="text-muted d-block">Năm sản xuất</small>
                                            <strong id="previewYear">-</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="spec-item">
                                            <small class="text-muted d-block">Kích thước khung</small>
                                            <strong id="previewFrameSize">-</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="spec-item">
                                            <small class="text-muted d-block">Màu sắc</small>
                                            <strong id="previewColor">-</strong>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="spec-item">
                                            <small class="text-muted d-block">
                                                <i class="bi bi-geo-alt"></i> Địa điểm
                                            </small>
                                            <strong id="previewLocation">-</strong>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="preview-description">
                                <h5 class="mb-3" style="font-size: 18px; font-weight: 600;">Mô tả</h5>
                                <p id="previewDescription" class="text-muted" style="line-height: 1.6;">Chưa có mô tả</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Đóng
                </button>
                <button type="button" class="btn btn-success" onclick="confirmSubmit()">
                    <i class="bi bi-check-circle"></i> Xác nhận lưu thay đổi
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const MAX_WIDTH = 1200;
        const MAX_HEIGHT = 1200;
        const IMAGE_QUALITY = 0.7;

        function resizeImage(file) {
            return new Promise((resolve) => {
                if (!file.type.startsWith('image/')) {
                    resolve(file);
                    return;
                }
                const reader = new FileReader();
                reader.onload = function (e) {
                    const img = new Image();
                    img.onload = function () {
                        let width = img.width;
                        let height = img.height;

                        if (width <= MAX_WIDTH && height <= MAX_HEIGHT) {
                            resolve(file);
                            return;
                        }

                        if (width > height) {
                            if (width > MAX_WIDTH) {
                                height = Math.round(height * MAX_WIDTH / width);
                                width = MAX_WIDTH;
                            }
                        } else {
                            if (height > MAX_HEIGHT) {
                                width = Math.round(width * MAX_HEIGHT / height);
                                height = MAX_HEIGHT;
                            }
                        }

                        const canvas = document.createElement('canvas');
                        canvas.width = width;
                        canvas.height = height;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, width, height);

                        canvas.toBlob(function (blob) {
                            const resizedFile = new File([blob], file.name, {
                                type: 'image/jpeg',
                                lastModified: Date.now()
                            });
                            console.log(`🖼️ Resized ${file.name}: ${(file.size / 1024).toFixed(0)}KB → ${(resizedFile.size / 1024).toFixed(0)}KB`);
                            resolve(resizedFile);
                        }, 'image/jpeg', IMAGE_QUALITY);
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        function deleteImage(imageId) {
            if (!confirm('Bạn có chắc muốn xóa ảnh này?')) return;
            document.getElementById('deleteImageId').value = imageId;
            document.getElementById('deleteImageForm').submit();
        }

        let newSelectedFiles = [];
        let existingImageUrls = [];

        // Get existing images on page load
        document.addEventListener('DOMContentLoaded', function() {
            const existingImages = document.querySelectorAll('.existing-image');
            existingImageUrls = Array.from(existingImages).map(img => img.getAttribute('data-url'));
            console.log(`📷 Existing images: ${existingImageUrls.length}`);
        });

        // Handle new file input change
        document.getElementById('newImages').addEventListener('change', function () {
            const preview = document.getElementById('editImagePreview');
            const uploadTile = preview.querySelector('.image-upload-tile');
            preview.querySelectorAll('.image-preview-wrapper.new-image').forEach(item => item.remove());

            newSelectedFiles = Array.from(this.files);
            console.log(`📸 Selected ${newSelectedFiles.length} new files`);

            newSelectedFiles.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function (event) {
                    const wrapper = document.createElement('div');
                    wrapper.classList.add('image-preview-wrapper', 'new-image');

                    const img = document.createElement('img');
                    img.src = event.target.result;
                    img.classList.add('image-preview-item');

                    wrapper.appendChild(img);
                    preview.insertBefore(wrapper, uploadTile);
                };
                reader.readAsDataURL(file);
            });
        });

        function showPreview() {
            // Get form values
            const title = document.getElementById('titleInput').value || 'Chưa có tiêu đề';
            const description = document.getElementById('descriptionInput').value || 'Chưa có mô tả';
            const brandSelect = document.getElementById('brandInput');
            const brand = brandSelect.options[brandSelect.selectedIndex]?.text || '-';
            const categorySelect = document.getElementById('categoryInput');
            const category = categorySelect.options[categorySelect.selectedIndex]?.text || '-';
            const price = document.getElementById('priceInput').value;
            const frameSize = document.getElementById('frameSizeInput').value || '-';
            const conditionSelect = document.getElementById('conditionInput');
            const condition = conditionSelect.value || '-';
            const year = document.getElementById('yearInput').value || '-';
            const location = document.getElementById('locationInput').value || '-';
            const color = document.getElementById('colorInput').value || '-';
            const statusSelect = document.getElementById('statusInput');
            const status = statusSelect.value || 'available';

            // Update preview content
            document.getElementById('previewTitle').textContent = title;
            document.getElementById('previewDescription').textContent = description;
            document.getElementById('previewBrand').textContent = brand;
            document.getElementById('previewCategory').textContent = category;
            document.getElementById('previewFrameSize').textContent = frameSize;
            document.getElementById('previewYear').textContent = year;
            document.getElementById('previewLocation').textContent = location;
            document.getElementById('previewColor').textContent = color;

            // Update status badge
            const statusBadge = document.getElementById('previewStatusBadge');
            statusBadge.textContent = status.charAt(0).toUpperCase() + status.slice(1);
            statusBadge.className = 'badge';
            if (status === 'available') statusBadge.classList.add('bg-success');
            else if (status === 'sold') statusBadge.classList.add('bg-secondary');
            else if (status === 'pending') statusBadge.classList.add('bg-warning', 'text-dark');
            else if (status === 'denied') statusBadge.classList.add('bg-danger');
            else statusBadge.classList.add('bg-info');

            // Format and display condition
            const conditionBadge = document.getElementById('previewCondition');
            if (condition && condition !== '-') {
                conditionBadge.textContent = condition.charAt(0).toUpperCase() + condition.slice(1);
            } else {
                conditionBadge.textContent = '-';
            }

            // Format and display price
            if (price) {
                const formattedPrice = new Intl.NumberFormat('vi-VN', { 
                    style: 'currency', 
                    currency: 'VND' 
                }).format(price);
                document.getElementById('previewPrice').textContent = formattedPrice;
            } else {
                document.getElementById('previewPrice').textContent = '0 ₫';
            }

            // Update carousel with existing + new images
            const carouselInner = document.getElementById('previewCarouselInner');
            const carouselIndicators = document.getElementById('previewCarouselIndicators');
            carouselInner.innerHTML = '';
            carouselIndicators.innerHTML = '';

            let imageIndex = 0;

            // Add existing images
            existingImageUrls.forEach((url, index) => {
                const carouselItem = document.createElement('div');
                carouselItem.classList.add('carousel-item');
                if (imageIndex === 0) carouselItem.classList.add('active');

                const img = document.createElement('img');
                img.src = url;
                img.classList.add('d-block', 'w-100');
                img.style.height = '400px';
                img.style.objectFit = 'cover';
                img.alt = `Existing Image ${index + 1}`;

                carouselItem.appendChild(img);
                carouselInner.appendChild(carouselItem);

                // Create indicator
                const indicator = document.createElement('button');
                indicator.type = 'button';
                indicator.setAttribute('data-bs-target', '#previewCarousel');
                indicator.setAttribute('data-bs-slide-to', imageIndex.toString());
                if (imageIndex === 0) indicator.classList.add('active');
                carouselIndicators.appendChild(indicator);

                imageIndex++;
            });

            // Add new images
            newSelectedFiles.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function (event) {
                    const carouselItem = document.createElement('div');
                    carouselItem.classList.add('carousel-item');
                    if (imageIndex === 0) carouselItem.classList.add('active');

                    const img = document.createElement('img');
                    img.src = event.target.result;
                    img.classList.add('d-block', 'w-100');
                    img.style.height = '400px';
                    img.style.objectFit = 'cover';
                    img.alt = `New Image ${index + 1}`;

                    carouselItem.appendChild(img); 
                    carouselInner.appendChild(carouselItem);

                    // Create indicator
                    const indicator = document.createElement('button');
                    indicator.type = 'button';
                    indicator.setAttribute('data-bs-target', '#previewCarousel');
                    indicator.setAttribute('data-bs-slide-to', imageIndex.toString());
                    if (imageIndex === 0) indicator.classList.add('active');
                    carouselIndicators.appendChild(indicator);

                    imageIndex++;
                };
                reader.readAsDataURL(file);
            });

            // If no images at all
            if (existingImageUrls.length === 0 && newSelectedFiles.length === 0) {
                const carouselItem = document.createElement('div');
                carouselItem.classList.add('carousel-item', 'active');
                carouselItem.innerHTML = `
                    <div style="background: #f5f5f5; height: 400px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                        <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                        <p class="text-muted mt-3">Chưa có hình ảnh</p>
                    </div>
                `;
                carouselInner.appendChild(carouselItem);
            }

            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('previewModal'));
            modal.show();
        }

        function confirmSubmit() {
            const title = document.getElementById('titleInput').value;
            const price = document.getElementById('priceInput').value;
            const brand = document.getElementById('brandInput').value;
            const category = document.getElementById('categoryInput').value;
            const condition = document.getElementById('conditionInput').value;

            if (!title || !price || !brand || !category || !condition) {
                alert('Vui lòng điền đầy đủ các trường bắt buộc!');
                const modal = bootstrap.Modal.getInstance(document.getElementById('previewModal'));
                modal.hide();
                return;
            }

            const modal = bootstrap.Modal.getInstance(document.getElementById('previewModal'));
            modal.hide();

            setTimeout(() => {
                console.log('📤 Submitting edit form...');
                document.getElementById('editForm').requestSubmit();
            }, 300);
        }

        // Intercept form submit to resize images
        document.getElementById('editForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const form = e.target;
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalBtnHtml = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý ảnh...';

            try {
                const formData = new FormData(form);

                // Remove original files from formData
                formData.delete('newImages');

                // Resize and append new images
                const fileInput = document.getElementById('newImages');
                const files = Array.from(fileInput.files);

                if (files.length > 0) {
                    console.log(`🔄 Resizing ${files.length} images...`);
                    const resizedFiles = await Promise.all(files.map(f => resizeImage(f)));
                    resizedFiles.forEach(file => {
                        formData.append('newImages', file, file.name);
                    });
                    console.log('✅ All images resized');
                }

                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...';

                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });

                if (response.redirected) {
                    window.location.href = response.url;
                } else if (response.ok) {
                    const html = await response.text();
                    document.open();
                    document.write(html);
                    document.close();
                } else {
                    alert('Có lỗi xảy ra khi lưu. Vui lòng thử lại.');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnHtml;
                }
            } catch (error) {
                console.error('❌ Submit error:', error);
                alert('Có lỗi xảy ra. Vui lòng thử lại.');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnHtml;
            }
        });
    </script>
}
