@model DataAccess.Models.Brand

@{
    ViewData["Title"] = "Edit Brand";
}

<!-- Page Header -->
<div class="page-header">
    <h1><i class="bi bi-pencil"></i> Edit Brand</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Brands</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-tags"></i> Edit Brand #@Model.Id</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-tag"></i> Brand Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g., Giant, Trek, Specialized" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Enter a unique brand name
                        </small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-image"></i> Ảnh thương hiệu
                        </label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2">
                                <img id="currentImage" src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail" style="max-width: 200px;">
                            </div>
                        }
                        <input type="file" name="image" id="imageInput" class="form-control" accept="image/*" />
                        <span id="imageError" class="text-danger" style="display:none;"></span>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Chọn ảnh mới để thay đổi. Chỉ chấp nhận 1 file ảnh (JPG, PNG, GIF). Để trống nếu không muốn đổi ảnh.
                        </small>
                        <div id="imagePreview" class="mt-2" style="display:none;">
                            <p class="text-muted mb-1"><small>Ảnh mới:</small></p>
                            <img id="previewImg" src="" alt="Preview" class="img-thumbnail" style="max-width: 200px;">
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> <strong>Note:</strong> This brand is currently used by <strong>@Model.Vehicles.Count</strong> vehicle(s).
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('imageInput').addEventListener('change', function () {
            const file = this.files[0];
            const errorEl = document.getElementById('imageError');
            const previewEl = document.getElementById('imagePreview');
            const previewImg = document.getElementById('previewImg');

            errorEl.style.display = 'none';
            errorEl.textContent = '';
            previewEl.style.display = 'none';

            if (!file) return;

            const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
            if (!allowedTypes.includes(file.type)) {
                errorEl.textContent = 'Chỉ chấp nhận file ảnh (JPG, PNG, GIF, WEBP).';
                errorEl.style.display = 'block';
                this.value = '';
                return;
            }

            const maxSize = 5 * 1024 * 1024;
            if (file.size > maxSize) {
                errorEl.textContent = 'File ảnh không được vượt quá 5MB.';
                errorEl.style.display = 'block';
                this.value = '';
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                previewImg.src = e.target.result;
                previewEl.style.display = 'block';
            };
            reader.readAsDataURL(file);
        });
    </script>
}
