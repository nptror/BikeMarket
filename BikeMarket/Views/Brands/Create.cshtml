@model DataAccess.Models.Brand

@{
    ViewData["Title"] = "Create Brand";
}

<!-- Page Header -->
<div class="page-header">
    <h1><i class="bi bi-plus-circle"></i> Create New Brand</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Brands</a></li>
            <li class="breadcrumb-item active">Create</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-tags"></i> Brand Information</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-tag"></i> Brand Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g., Giant, Trek, Specialized" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Enter a unique brand name
                        </small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-image"></i> Brand Image <span class="text-danger">*</span>
                        </label>
                        <input type="file" name="image" class="form-control" accept="image/*" />
                        <span class="text-danger">@Html.ValidationMessage("ImageUrl")</span>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Upload a clear brand logo or image
                        </small>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-secondary">
                            <i class="bi bi-check-circle"></i> Create Brand
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
