@using DTO.Vehicle
@using DataAccess.Models
@using BikeMarket.Models
@using System.Linq

@model HomeIndexViewModel

@{
    ViewData["Title"] = "Home";

    var keyword = Model.Keyword ?? string.Empty;
    var selectedCategory = Model.CategoryId?.ToString() ?? string.Empty;
    var selectedBrandId = Model.BrandId;

    var categoryOptions = Model.Categories
        .Select(c => (c.Id.ToString(), c.Name))
        .ToList();
}

<div class="home-hero">
    <div class="home-search-wrapper">
        <form class="home-search-bar" method="get" asp-controller="Home" asp-action="Index">
            <div class="home-search-group">
                <select class="form-select home-search-category" name="categoryId">
                    <option value="">Danh mục</option>
                    @foreach (var option in categoryOptions)
                    {
                        <option value="@option.Item1" selected="@(option.Item1 == selectedCategory)">@option.Item2</option>
                    }
                </select>
                <div class="home-search-input">
                    <i class="bi bi-search"></i>
                    <input class="form-control" type="text" name="keyword" value="@keyword" placeholder="Tìm tên xe..." />
                </div>
                @if (selectedBrandId.HasValue)
                {
                    <input type="hidden" name="brandId" value="@selectedBrandId" />
                }
                <button class="btn home-search-button" type="submit">Tìm kiếm</button>
            </div>
        </form>

        @if (Model.Brands.Any())
        {
            <div class="home-brand-cards">
                @foreach (var brand in Model.Brands)
                {
                    var isActive = selectedBrandId.HasValue && brand.Id == selectedBrandId.Value;
                    <a class="home-brand-card @(isActive ? "active" : string.Empty)"
                       asp-controller="Home"
                       asp-action="Index"
                       asp-route-brandId="@brand.Id"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-keyword="@Model.Keyword">
                        <div class="home-brand-image">
                            <img src="@brand.ImageUrl" alt="@brand.Name" />
                        </div>
                        <div class="home-brand-name">@brand.Name</div>
                    </a>
                }
            </div>
        }
    </div>
</div>

<h2 class="mt-4">Bike Marketplace</h2>

<div class="row">
    @foreach (var item in Model.Vehicles)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100 shadow-sm">

                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                {
                    <img src="@item.ThumbnailUrl" class="card-img-top" style="height:180px; object-fit:cover;" />
                }
                else
                {
                    <div style="height:180px; background:#eee; display:flex; align-items:center; justify-content:center;">
                        <span>No Image</span>
                    </div>
                }

                <div class="card-body">
                    <h5 class="card-title">@item.Title</h5>

                    <p class="card-text mb-1">
                        <b>Brand:</b> @item.BrandName
                    </p>

                    <p class="card-text mb-1">
                        <b>Category:</b> @item.CategoryName
                    </p>

                    <p class="card-text mb-1">
                        <b>Price:</b> @item.Price.ToString("N0") ₫
                    </p>

                    <p class="card-text mb-1">
                        <b>Location:</b> @item.Location
                    </p>

                    <p class="card-text text-muted" style="font-size: 13px;">
                        Posted: @(item.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")
                    </p>
                </div>

                <div class="card-footer bg-white">
                    <a class="btn btn-primary w-100"
                       asp-controller="Vehicles"
                       asp-action="DetailsBuyer"
                       asp-route-id="@item.VehicleId">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
